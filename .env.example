# =============================================
# EPCO - Variables de Entorno
# Opción 1: Usar 'bash start.sh' para auto-detectar puertos libres
# Opción 2: Copiar como .env y ajustar manualmente
# =============================================

# Puertos (se auto-detectan con start.sh)
# Si están ocupados, start.sh buscará el siguiente disponible
APP_PORT=8080
DB_PORT=3306
PMA_PORT=8081

# Entorno (development / production)
APP_ENV=production

# Base de datos
DB_NAME=epco
DB_USER=epco_user
DB_PASS=CambiarEstaContraseña
DB_ROOT_PASSWORD=CambiarContraseñaRoot

# =============================================
# SMTP - Servicio de Correo
# =============================================
# Activar envío de correos (true/false)
SMTP_ENABLED=true

# URL de la aplicación (para enlaces en correos)
APP_URL=http://localhost:8080

# Modo de envío:
#   relay  - Usa microservicio Postfix en Docker (RECOMENDADO)
#   direct - Conexión directa al SMTP externo
SMTP_MODE=relay

# Servidor SMTP externo (el relay lo usa para reenviar)
#   Outlook personal: smtp-mail.outlook.com  (puerto 587, tls)
#   Office 365:       smtp.office365.com      (puerto 587, tls)
#   Gmail:            smtp.gmail.com          (puerto 587, tls)
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls

# Credenciales del correo remitente
# IMPORTANTE: No commitear credenciales reales. Configurar en .env o Portainer.
SMTP_USER=tu-correo@outlook.com
SMTP_PASS=tu-password

# Remitente (from)
SMTP_FROM_EMAIL=tu-correo@outlook.com
SMTP_FROM_NAME=Soporte TI - EPCO

# =============================================
# Destinatarios de Notificaciones
# Separar múltiples correos con coma
# Ej: admin@empresa.cl,soporte@empresa.cl
# =============================================
NOTIFY_TICKET_CREATED=correo1@empresa.cl,correo2@empresa.cl
NOTIFY_TICKET_UPDATED=correo1@empresa.cl
